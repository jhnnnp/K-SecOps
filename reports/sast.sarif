              }
            }
          ]
        },
        {
          "ruleId": "sast.os_system",
          "level": "error",
          "message": {
            "text": "os.system(payload)"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "dummy-infra/code/unsafe_sast.py"
                },
                "region": {
                  "startLine": 9
