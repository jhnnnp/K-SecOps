# Agentic K-SecOps — local development (optional)
# Copy to .env and adjust as needed.

K_SECOPS_HOST=0.0.0.0
K_SECOPS_PORT=8000
K_SECOPS_LOG_LEVEL=info

# Set to 1 to enable boto3 live S3 PublicAccessBlock scan (requires AWS credentials)
SECOPS_AWS_LIVE=0
# Set to 1 for repository-wide secret scanning (CI scripts). MCP agents stay sandboxed.
SECOPS_REPO_SCAN=0
SECOPS_SECRETS_TARGET=.
SECOPS_INFRA_TARGETS=dummy-infra,Dockerfile
SECOPS_TARGET=dummy-infra

# SecOps alerting (Go alert-worker) — Slack or Discord incoming webhook
# SECOPS_ALERT_WEBHOOK=https://hooks.slack.com/services/...
# SECOPS_ALERT_FORMAT=slack
