{
  "version": 2,
  "description": "Dual-target CI baseline. Secrets in dummy-infra/ are known fixtures; secrets anywhere else fail unconditionally. Infrastructure CRITICAL gate applies only to dummy-infra/ regression fixtures.",
  "target": "dummy-infra",
  "fixture_secret_prefixes": ["dummy-infra/"],
  "infra_baseline_prefixes": ["dummy-infra/"],
  "allowed_finding_keys": [
    "scan_infrastructure|CKV_K8S_23|dummy-infra/k8s/deployment-vulnerable.yaml",
    "scan_infrastructure|CKV_K8S_38|dummy-infra/k8s/service-nodeport.yaml",
    "audit_secrets|secret.aws_access_key|dummy-infra/.env.leaked",
    "audit_secrets|secret.aws_secret_key|dummy-infra/.env.leaked",
    "audit_secrets|secret.api_key|dummy-infra/.env.leaked",
    "audit_aws|aws.s3_public_access|dummy-infra/aws/s3-public-bucket-policy.json",
    "audit_aws|aws.iam_overprivileged|dummy-infra/aws/iam-admin-policy.json"
  ],
  "fail_on_scan_critical": true,
  "fail_on_scanner_errors": true
}
